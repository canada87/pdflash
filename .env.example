# Copy to .env and adjust as needed.
# docker compose automatically reads .env from the project root.

# Host port the app listens on (default 8000)
PORT=8000

# Local folder to watch for new PDFs (bind-mounted into the container)
PDF_DIR=./pdfs

# Render workers (cores used for parallel page rendering; default = min(cpu, 4))
PDFLASH_WORKERS=4

# WebP resolution tiers (pixels on the long edge)
PDFLASH_TIER_THUMB_PX=200
PDFLASH_TIER_SCREEN_PX=1400
PDFLASH_TIER_HI_PX=2800

# WebP quality per tier (0-100)
PDFLASH_WEBP_QUALITY_THUMB=70
PDFLASH_WEBP_QUALITY_SCREEN=80
PDFLASH_WEBP_QUALITY_HI=82
